PORT=5000
MONGO_URI=mongodb://localhost:27017/recipe_db
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development

# Default: Groq (open Llama models, free tier)
# Get API key: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# Other Groq models: llama-3.1-8b-instant | mixtral-8x7b-32768 | gemma2-9b-it

# Local open-source: LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# Paid: LLM_PROVIDER=openai
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini
